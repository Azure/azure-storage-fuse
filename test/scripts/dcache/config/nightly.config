# Shared configuration for the dist_cache nightly E2E scripts.
#
# All values may be overridden via environment variables using the
# ${VAR:-default} pattern; this lets the ADO pipeline inject secrets / image
# coordinates from a variable group without editing this file.
#
# The cluster substrate is `kind` (Kubernetes IN Docker). We deliberately do
# NOT reuse vienna-tachyon's minikube tooling; see
# test/scripts/dcache/PLAN.md §1 for the rationale.

CLUSTER_NAME="${CLUSTER_NAME:-blobfuse-dcache}"
NAMESPACE="${NAMESPACE:-cache-server}"
RELEASE_NAME="${RELEASE_NAME:-cache-server}"
PREREQ_RELEASE_NAME="${PREREQ_RELEASE_NAME:-cache-server-prereq}"

# Kind cluster shape. KIND_NODES is a *total* count (control-plane + workers),
# kept at 4 to match the shape Tachyon's Helm chart is tuned for.
KIND_NODES="${KIND_NODES:-4}"
KIND_NODE_IMAGE="${KIND_NODE_IMAGE:-kindest/node:v1.31.0}"
KIND_CLUSTER_CONFIG="${KIND_CLUSTER_CONFIG:-}"   # populated by setup-kind.sh

CACHE_SERVER_PORT="${CACHE_SERVER_PORT:-9065}"
CACHE_SERVER_METRICS_PORT="${CACHE_SERVER_METRICS_PORT:-9096}"
CACHE_SERVER_REPLICAS="${CACHE_SERVER_REPLICAS:-3}"

# Tachyon image coordinates. The pipeline overrides these via env vars sourced
# from the NightlyBlobFuse variable group.
# TBD: set these values when the ACR name and image tag are known.
CACHE_SERVER_IMAGE_REGISTRY="${CACHE_SERVER_IMAGE_REGISTRY:-}"
CACHE_SERVER_IMAGE_REPO="${CACHE_SERVER_IMAGE_REPO:-cache-server}"
CACHE_SERVER_IMAGE_TAG="${CACHE_SERVER_IMAGE_TAG:-}"

# Tachyon Helm chart coordinates, pulled from an OCI-enabled ACR.
# Defaults to the same registry as the image; override _CHART_REGISTRY only if
# the chart lives in a different ACR from the image.
# The prereq chart (CRDs / RBAC / cluster-scoped resources the main chart
# depends on) is installed first, using the SAME version as the main chart.
# TBD: set _CHART_VERSION to the exact version published in the ACR.
CACHE_SERVER_CHART_REGISTRY="${CACHE_SERVER_CHART_REGISTRY:-${CACHE_SERVER_IMAGE_REGISTRY}}"
CACHE_SERVER_CHART_REPO="${CACHE_SERVER_CHART_REPO:-charts/cache-server}"
CACHE_SERVER_PREREQ_CHART_REPO="${CACHE_SERVER_PREREQ_CHART_REPO:-charts/cache-server-prereq}"
CACHE_SERVER_CHART_VERSION="${CACHE_SERVER_CHART_VERSION:-}"
